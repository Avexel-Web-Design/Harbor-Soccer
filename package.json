{
  "name": "harbor-soccer",
  "version": "1.0.0",
  "type": "module",
  "description": "Harbor Soccer Inc. website",
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "serve": "python3 -m http.server 8000",
    "sass": "sass --watch scss/:css/",
    "sass:build": "sass scss/:css/ --style=expanded --no-source-map",
    "format": "prettier --write \"**/*.{html,js,json,scss,css,md}\"",
    "lint:js": "eslint . --ext .js",
    "lint:scss": "stylelint \"scss/**/*.scss\"",
    "lint:html": "html-validate \"*.html\"",
    "check": "npm run lint:js && npm run lint:scss && npm run lint:html && npm run sass:build"
  },
  "keywords": [
    "soccer",
    "youth-sports",
    "harbor-springs"
  ],
  "author": "Harbor Soccer Inc.",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.22.0",
    "html-validate": "^10.1.2",
    "prettier": "^3.5.3",
    "sass": "^1.98.0",
    "stylelint": "^16.16.0",
    "stylelint-config-standard-scss": "^14.0.0"
  }
}
